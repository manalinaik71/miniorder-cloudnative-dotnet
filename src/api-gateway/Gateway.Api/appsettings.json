{
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/catalog/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/catalog" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/orders/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/orders" }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "d1": { "Address": "http://catalog-service:8080/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "d1": { "Address": "http://order-service:8080/" }
        }
      }
    }
  }
}